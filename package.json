{
  "name": "gitops-export-console",
  "version": "0.1.0",
  "description": "OpenShift console plugin for namespace-scoped GitOps export review",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/turbra/gitops-export-plugin.git"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "check-types": "tsc --noEmit --skipLibCheck",
    "clean": "rm -rf dist",
    "build": "npm run clean && NODE_ENV=production npm run webpack",
    "build-dev": "npm run clean && npm run webpack",
    "start": "webpack serve --progress",
    "start-console": "./start-console.sh",
    "i18n": "i18next \"src/**/*.{js,jsx,ts,tsx}\" -c i18next-parser.config.js",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "webpack": "node -r ts-node/register ./node_modules/.bin/webpack",
    "test:fixtures": "ts-node scripts/test-fixtures.ts",
    "generate-fixtures": "ts-node scripts/generate-fixtures.ts"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@openshift-console/dynamic-plugin-sdk": "4.21-latest",
    "@openshift-console/dynamic-plugin-sdk-webpack": "4.21-latest",
    "@patternfly/react-core": "^6.2.2",
    "@patternfly/react-icons": "^6.2.2",
    "@types/node": "^22.0.0",
    "@types/react": "^17.0.37",
    "@types/react-router-dom": "^5.3.3",
    "babel-loader": "^10.1.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^9.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "i18next": "^23.11.5",
    "i18next-parser": "^9.0.2",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "react-i18next": "^11.7.3",
    "react-router": "5.3.x",
    "react-router-dom": "5.3.x",
    "react-router-dom-v5-compat": "^6.11.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.100.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1"
  }
}
